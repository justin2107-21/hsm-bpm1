# HSM Supabase Project Configuration (Your own project)
# Get these from your Supabase dashboard at https://supabase.com/dashboard
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_key"
VITE_SUPABASE_URL="your_supabase_url"

# Important: VITE_ prefix makes these variables accessible in the frontend (Vite)
# Only use PUBLIC/non-sensitive data here!

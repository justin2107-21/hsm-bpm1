# CIE (Classmate's) Supabase Project Configuration
# Get these from your classmate's Supabase dashboard
CIE_SUPABASE_URL="https://tjcwwocpkpmhtdtlsiuc.supabase.co"
CIE_SERVICE_ROLE_KEY="your_service_role_key_from_cie_project"

# Your own HSM Supabase project configuration (optional, for future use)
HSM_SUPABASE_URL="your_hsm_supabase_url"
HSM_ANON_KEY="your_hsm_anon_key"

# Table configuration
# Set this to the actual table name in the CIE database that contains citizen profiles
CITIZENS_TABLE=profiles

# Server port (optional)
PORT=5000

# IMPORTANT SECURITY NOTES:
# 1. CIE_SERVICE_ROLE_KEY must NEVER be exposed to the frontend
# 2. Keep this file in .gitignore (it's already in .gitignore)
# 3. For deployment, set these variables as environment variables in your hosting platform
